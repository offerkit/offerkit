{
  "name": "@offerkit/worker",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=html --coverage.reporter=lcov --coverage.reporter=json-summary --passWithNoTests"
  },
  "dependencies": {
    "@offerkit/core": "workspace:*",
    "@offerkit/db": "workspace:*",
    "@opentelemetry/api": "^1.9.1"
  },
  "devDependencies": {
    "@offerkit/config": "workspace:*",
    "@types/node": "^26.0.1",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
