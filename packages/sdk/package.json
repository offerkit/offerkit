{
  "name": "@offerkit/sdk",
  "version": "0.2.6",
  "license": "MIT",
  "type": "module",
  "description": "Typed client for the OfferKit promotions API.",
  "repository": {
    "type": "git",
    "url": "https://github.com/offerkit/offerkit.git",
    "directory": "packages/sdk"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=html --coverage.reporter=lcov --coverage.reporter=json-summary --passWithNoTests",
    "prepublishOnly": "tsdown"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      }
    }
  },
  "dependencies": {
    "@orpc/client": "^1.14.2",
    "@orpc/contract": "^1.14.2",
    "@orpc/openapi-client": "^1.14.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@offerkit/config": "workspace:*",
    "@offerkit/contract": "workspace:*",
    "@types/node": "^26.0.1",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
