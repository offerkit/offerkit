{
  "name": "@offerkit/cli",
  "version": "0.2.0",
  "license": "MIT",
  "type": "module",
  "description": "OfferKit command-line interface.",
  "repository": {
    "type": "git",
    "url": "https://github.com/offerkit/offerkit.git",
    "directory": "packages/cli"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "tsdown"
  },
  "publishConfig": {
    "access": "public",
    "bin": {
      "offerkit": "./dist/index.mjs"
    },
    "main": "./dist/index.mjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "dependencies": {
    "@offerkit/sdk": "workspace:^",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@offerkit/config": "workspace:*",
    "@types/node": "^25.6.2",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
