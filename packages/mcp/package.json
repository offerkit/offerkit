{
  "name": "@offerkit/mcp",
  "version": "0.2.3",
  "license": "MIT",
  "type": "module",
  "description": "OfferKit MCP server - exposes the OfferKit API as Model Context Protocol tools.",
  "repository": {
    "type": "git",
    "url": "https://github.com/offerkit/offerkit.git",
    "directory": "packages/mcp"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=html --coverage.reporter=lcov --coverage.reporter=json-summary --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsdown"
  },
  "publishConfig": {
    "access": "public",
    "bin": {
      "offerkit-mcp": "./dist/index.mjs"
    },
    "main": "./dist/index.mjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@offerkit/sdk": "workspace:^",
    "@orpc/contract": "^1.14.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@offerkit/config": "workspace:*",
    "@offerkit/contract": "workspace:*",
    "@types/node": "^26.0.0",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
