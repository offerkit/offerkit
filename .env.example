# --- Required ---
DATABASE_URL=postgres://offerkit:dev@localhost:5432/offerkit

# 32+ char secret used by Better Auth to sign sessions
BETTER_AUTH_SECRET=please-change-this-32-chars-min-secret

# Public origin where the app is reachable (used for cookies, callbacks, OpenAPI server)
OFFERKIT_PUBLIC_URL=http://localhost:3000

# --- First-boot admin seed (only required on an empty database) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# --- Optional ---
# If set, transactional email (password reset, user invites) goes through Resend.
# If unset, emails are logged to stdout — perfect for local dev.
# RESEND_API_KEY=
# RESEND_FROM=Offerkit <onboarding@resend.dev>

# --- Observability (OpenTelemetry → any OTLP-compatible backend, e.g. Axiom) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.axiom.co
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer <AXIOM_API_TOKEN>,X-Axiom-Dataset=offerkit
# OTEL_SDK_DISABLED=false

# --- Worker tuning ---
# WORKER_HEALTH_PORT=9091
