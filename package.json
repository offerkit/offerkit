{
  "name": "offerkit",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "fallow": "pnpm dlx fallow",
    "prepare": "lefthook install || true",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=@offerkit/sdk --filter=@offerkit/cli --filter=@offerkit/mcp && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "^10.5.0",
    "lefthook": "^2.1.9",
    "turbo": "^2.9.18"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.1",
      "hono": "4.12.21",
      "qs": "6.15.2"
    }
  }
}
